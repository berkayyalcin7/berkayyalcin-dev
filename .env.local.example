# Supabase proje ayarların > Project Settings > API sekmesinden alabilirsin.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sadece sunucu tarafında (admin işlemleri) kullanılacak, ASLA client'a sızdırma.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site ayarları
NEXT_PUBLIC_SITE_URL=https://berkayyalcin.dev

# /api/revalidate endpoint'i için gizli anahtar (ör. `openssl rand -hex 32` çıktısı).
# Vercel'de de Production ortamına eklenmeli. Tanımlı değilse endpoint 503 döner.
REVALIDATE_SECRET=your-strong-random-secret
